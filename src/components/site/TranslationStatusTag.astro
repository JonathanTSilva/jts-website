---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span class="translation-status-tag">
  <span class="translation-status-dot" aria-hidden="true"></span>
  <span>{text}</span>
</span>

<style>
  .translation-status-tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    width: fit-content;
    padding: var(--space-1) var(--space-3);
    border: 1px solid color-mix(in srgb, #f59e0b 35%, var(--border));
    border-radius: var(--radius-full);
    background: color-mix(in srgb, #f59e0b 10%, var(--surface));
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.2;
  }

  .translation-status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-full);
    background: #f59e0b;
    flex-shrink: 0;
  }
</style>