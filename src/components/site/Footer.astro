---
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: 'en' | 'pt-br';
  currentPath: string;
  translations?: Partial<Record<'en' | 'pt-br', string>> | undefined;
}

const { locale, currentPath, translations } = Astro.props;
const currentYear = new Date().getFullYear();

const t = {
  en: {
    rights: 'All rights reserved.',
    privacy: 'Privacy Policy',
    terms: 'Terms of Service',
  },
  'pt-br': {
    rights: 'Todos os direitos reservados.',
    privacy: 'Política de Privacidade',
    terms: 'Termos de Serviço',
  },
}[locale];
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Row 1: brand | social | lang -->
    <div class="footer-row footer-row-brand">
      <!-- Logo + name -->
      <div class="footer-logo">
        <img src="/assets/images/jts-logo-circle-simple.png" alt="JTS logo" class="footer-logo-img" width="24" height="24" />
        <span class="footer-name">Tobias</span>
      </div>

      <!-- Social icons -->
      <div class="footer-social">
        <a
          href="https://www.linkedin.com/in/jonathantsilva/"
          aria-label="LinkedIn"
          rel="noopener noreferrer"
          target="_blank"
          class="footer-social-link"
          data-analytics-event="linkedin_click"
          data-analytics-props={`{"surface":"footer","locale":"${locale}"}`}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href="https://github.com/JonathanTSilva"
          aria-label="GitHub"
          rel="noopener noreferrer"
          target="_blank"
          class="footer-social-link"
          data-analytics-event="github_click"
          data-analytics-props={`{"surface":"footer","locale":"${locale}"}`}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
          </svg>
        </a>
        <a
          href="mailto:jonathantosilva@hotmail.com"
          aria-label="Email"
          class="footer-social-link"
          data-analytics-event="email_click"
          data-analytics-props={`{"surface":"footer","locale":"${locale}"}`}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-10 7L2 7"/>
          </svg>
        </a>
        <a href="/rss.xml" aria-label="RSS feed" target="_blank" class="footer-social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
      </div>

      <!-- Language switcher -->
      <LanguageSwitcher currentLocale={locale} currentPath={currentPath} translations={translations} />
    </div>

    <!-- Row 2: copyright | legal links -->
    <div class="footer-row footer-row-legal">
      <p class="footer-copy">&copy; {currentYear} Jonathan Tobias da Silva. {t.rights}</p>
      <div class="footer-legal-links">
        <a href={locale === 'en' ? '/privacy' : `/${locale}/privacy`}>{t.privacy}</a>
        <a href={locale === 'en' ? '/terms' : `/${locale}/terms`}>{t.terms}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface-high);
    border-top: 1px solid var(--border);
    padding-block: var(--space-8);
    color: var(--text-muted);
  }

  .footer-inner {
    max-width: var(--wide-max);
    margin-inline: auto;
    padding-inline: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Row base */
  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-block: var(--space-4);
  }

  /* Row separator */
  .footer-row-legal {
    border-top: 1px solid var(--border);
  }

  /* Logo */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .footer-logo-img {
    width: var(--logo-size);
    height: var(--logo-size);
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }
  .footer-name {
    font-family: var(--font-logo);
    font-size: var(--logo-size);
    font-weight: var(--weight-bold);
    color: var(--text);
    line-height: 1;
  }

  /* Social icons */
  .footer-social {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .footer-social-link {
    color: var(--text-muted);
    text-decoration: none;
    display: flex;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .footer-social-link:hover { color: var(--accent); text-decoration: none; }

  /* Legal row */
  .footer-copy {
    margin: 0;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-muted);
  }
  .footer-legal-links {
    display: flex;
    gap: var(--space-4);
    align-items: center;
  }
  .footer-legal-links a {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .footer-legal-links a:hover { color: var(--accent); text-decoration: none; }

  /* Mobile */
  @media (max-width: 48rem) {
    .footer-row {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-row-legal {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
