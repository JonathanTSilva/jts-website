---
import { generateSeo, type SeoProps } from '../../lib/seo/metadata';

interface Props extends SeoProps {}

const seo = generateSeo(Astro.props);
---

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonical} />

{seo.alternateLocales.filter((alt) => alt.locale !== 'x-default').map((alt) => (
  <link rel="alternate" hreflang={alt.locale} href={alt.href} />
))}
{(() => {
  const xDefault = seo.alternateLocales.find((alt) => alt.locale === 'x-default');
  return xDefault ? <link rel="alternate" hreflang="x-default" href={xDefault.href} /> : null;
})()}

<!-- Open Graph -->
<meta property="og:title" content={seo.og.title} />
<meta property="og:description" content={seo.og.description} />
<meta property="og:type" content={seo.og.type} />
<meta property="og:url" content={seo.og.url} />
<meta property="og:image" content={seo.og.image} />
<meta property="og:image:secure_url" content={seo.og.image} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={seo.og.site_name} />
<meta property="og:locale" content={seo.og.locale} />

<!-- Twitter -->
<meta name="twitter:card" content={seo.twitter.card} />
<meta name="twitter:title" content={seo.twitter.title} />
<meta name="twitter:description" content={seo.twitter.description} />
<meta name="twitter:image" content={seo.twitter.image} />
