<script>
  import { getAnalyticsConfig } from '../../lib/analytics/config';
  import {
    CONSENT_STORAGE_KEY,
    parseConsentState,
    hasAnalyticsConsent as checkConsentState,
  } from '../../lib/analytics/consent';
  import { ANALYTICS_EVENT_NAMES } from '../../lib/analytics/events';

  // Plausible attaches to window — declare the minimal shape we use.
  declare global {
    interface Window {
      plausible?: ((eventName: string, opts?: { props?: Record<string, unknown> }) => void) & {
        q?: IArguments[];
      };
    }
  }

  const analyticsConfig = getAnalyticsConfig();
  const plausibleWindow = window;
  const analyticsScriptId = 'jts-plausible-script';

  const readConsent = () =>
    parseConsentState(window.localStorage.getItem(CONSENT_STORAGE_KEY));

  const hasAnalyticsConsent = () => checkConsentState(readConsent());

  const bootstrapPlausible = () => {
    if (typeof plausibleWindow.plausible !== 'function') {
      const stub = function () {
        (stub.q = stub.q || []).push(arguments);
      } as NonNullable<Window['plausible']>;
      plausibleWindow.plausible = stub;
    }
  };

  const loadAnalytics = () => {
    if (!analyticsConfig.enabled || !hasAnalyticsConsent()) {
      return;
    }

    if (document.getElementById(analyticsScriptId)) {
      return;
    }

    bootstrapPlausible();

    const script = document.createElement('script');
    script.id = analyticsScriptId;
    script.defer = true;
    script.dataset.analyticsScript = analyticsConfig.provider;
    script.dataset.domain = analyticsConfig.domain;
    if (analyticsConfig.apiHost !== 'https://plausible.io') {
      script.dataset.api = `${analyticsConfig.apiHost}/api/event`;
    }
    script.src = analyticsConfig.scriptSrc;
    document.head.appendChild(script);
  };

  const trackEvent = (eventName: string, props?: Record<string, unknown>) => {
    if (!ANALYTICS_EVENT_NAMES.includes(eventName as never) || !hasAnalyticsConsent()) {
      return;
    }

    bootstrapPlausible();
    plausibleWindow.plausible?.(eventName, props ? { props } : undefined);
  };

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) {
      return;
    }

    const trigger = target.closest('[data-analytics-event]');
    if (!(trigger instanceof HTMLElement)) {
      return;
    }

    const eventName = trigger.dataset.analyticsEvent;
    if (!eventName) {
      return;
    }

    const rawProps = trigger.dataset.analyticsProps;
    let props: Record<string, unknown> | undefined;

    if (rawProps) {
      try {
        props = JSON.parse(rawProps);
      } catch {
        props = undefined;
      }
    }

    trackEvent(eventName, props);
  });

  window.addEventListener('jts:consent-changed', () => {
    loadAnalytics();
  });

  loadAnalytics();
</script>
