---
import { getCollection } from 'astro:content';
import type { Locale } from '../../lib/content/locale';
import { contentLocalePath } from '../../lib/content/locale';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const allPosts = await getCollection('blog');

// Get all posts for the current locale, and all posts missing a translation in the current locale
const uniqueTranslationKeys = Array.from(new Set(allPosts.map(p => p.data.translationKey)));

const postsToShow = uniqueTranslationKeys.map(key => {
  const translations = allPosts.filter(p => p.data.translationKey === key);
  const currentLocalePost = translations.find(p => p.data.language === locale);
  if (currentLocalePost) {
    return { ...currentLocalePost, isTranslationMissing: false };
  } else {
    // Return the default locale post (or the first one available if default is not there)
    const fallbackPost = translations.find(p => p.data.language === 'en') || translations[0];
    if (!fallbackPost) return null;
    return { ...fallbackPost, isTranslationMissing: true };
  }
}).filter((p): p is NonNullable<typeof p> => p !== null)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Group by year and month
const groupedPosts = postsToShow.reduce((acc, post) => {
  const year = post.data.publishedAt.getFullYear();
  const month = post.data.publishedAt.getMonth();
  if (!acc[year]) acc[year] = {};
  const yearGroup = acc[year];
  if (yearGroup && !yearGroup[month]) yearGroup[month] = [];
  yearGroup?.[month]?.push(post);
  return acc;
}, {} as Record<number, Record<number, typeof postsToShow>>);

const years = Object.keys(groupedPosts).map(Number).sort((a, b) => b - a);

const monthNames = {
  en: ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'],
  'pt-br': ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
}[locale];

const translationMissingLabel = {
  en: 'Available in Portuguese only',
  'pt-br': 'Disponível apenas em Inglês',
}[locale];
---

<div class="blog-list">
  {years.map(year => {
    const months = groupedPosts[year] ? Object.keys(groupedPosts[year]!).map(Number).sort((a, b) => b - a) : [];
    return (
      <section class="year-group">
        <h2 class="year-title">{year}</h2>
        {months.map(month => (
          <div class="month-group">
            <h3 class="month-title">{monthNames[month]}</h3>
            <ul class="posts-list">
              {groupedPosts[year]?.[month]?.map(post => (
                <li class="post-item">
                  <a href={contentLocalePath(locale, `/blog/${post.data.slug}`)} class="post-link">
                    <span class="post-title">{post.data.title}</span>
                    {post.isTranslationMissing && (
                      <span class="translation-missing-tag">({translationMissingLabel})</span>
                    )}
                  </a>
                  <time datetime={post.data.publishedAt.toISOString()} class="post-date">
                    {post.data.publishedAt.toLocaleDateString(locale, { day: '2-digit' })}
                  </time>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    );
  })}
</div>

<style>
  .year-group {
    margin-bottom: var(--space-8);
  }
  .year-title {
    font-size: var(--text-2xl);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
  }
  .month-group {
    margin-left: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .month-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
    color: var(--text-muted);
    font-weight: 500;
  }
  .posts-list {
    list-style: none;
    padding: 0;
  }
  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-2) 0;
    border-bottom: 1px dashed var(--border);
    gap: var(--space-4);
  }
  .post-link {
    text-decoration: none;
    color: var(--accent);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }
  .post-link:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }
  .translation-missing-tag {
    font-size: var(--text-xs);
    color: #f59e0b;
    margin-left: var(--space-2);
    font-style: italic;
    white-space: nowrap;
  }
  .post-date {
    font-variant-numeric: tabular-nums;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
</style>
