---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../../lib/content/locale';
import { contentLocalePath } from '../../lib/content/locale';

interface Props {
  notes: CollectionEntry<'notes'>[];
  locale: Locale;
  heading: string;
}

const { notes, locale, heading } = Astro.props;
const dateLocale = locale === 'en' ? 'en-US' : 'pt-BR';
---

{notes.length > 0 && (
  <section class="related-section">
    <h2 class="related-heading">{heading}</h2>
    <div class="related-grid">
      {notes.map((note) => (
        <a
          href={contentLocalePath(locale, `/notes/${note.id}`)}
          class="note-preview-card"
        >
          <span class="note-preview-date">
            {note.data.publishedAt.toLocaleDateString(dateLocale, { dateStyle: 'medium' })}
          </span>
          <span class="note-preview-title">{note.data.title}</span>
          {note.data.category && (
            <span class="note-preview-category">{note.data.category}</span>
          )}
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-section {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
  }

  .related-heading {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .note-preview-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--card-padding);
    text-decoration: none;
    color: var(--text);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: box-shadow var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  .note-preview-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
    text-decoration: none;
  }

  .note-preview-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .note-preview-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
  }

  .note-preview-category {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-muted);
    margin-top: auto;
  }

  @media (max-width: 600px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
