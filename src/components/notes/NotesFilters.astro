---
import type { Locale } from '../../lib/content/locale';

interface Props {
  categories: string[];
  categoryCounts: Record<string, number>;
  tags: string[];
  locale: Locale;
}

const { categories, categoryCounts, tags, locale } = Astro.props;

const labels = {
  en: {
    all: 'All',
    categories: 'Categories',
    tags: 'Tags',
    clear: 'Clear filters',
    collapse: 'Collapse',
    expand: 'Expand',
  },
  'pt-br': {
    all: 'Tudo',
    categories: 'Categorias',
    tags: 'Tags',
    clear: 'Limpar filtros',
    collapse: 'Recolher',
    expand: 'Expandir',
  }
}[locale];
---

<nav class="notes-filters" id="notes-filters" aria-label="Filter notes">

  <details class="filter-section" open>
    <summary class="filter-section-header">
      <span class="filter-section-title">{labels.categories}</span>
      <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 4.5L6 8.5L10 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </summary>
    <div class="filter-items">
      <button class="filter-item active" data-filter="category" data-value="all">
        <span class="item-label">{labels.all}</span>
      </button>
      {categories.map(category => (
        <button class="filter-item" data-filter="category" data-value={category}>
          <span class="item-label">{category}</span>
          {categoryCounts[category] && (
            <span class="item-count">{categoryCounts[category]}</span>
          )}
        </button>
      ))}
    </div>
  </details>

  {tags.length > 0 && (
    <details class="filter-section" open>
      <summary class="filter-section-header">
        <span class="filter-section-title">{labels.tags}</span>
        <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 4.5L6 8.5L10 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </summary>
      <div class="filter-items">
        {tags.map(tag => (
          <button class="filter-item" data-filter="tag" data-value={tag}>
            <span class="item-tag-prefix">#</span>
            <span class="item-label">{tag}</span>
          </button>
        ))}
      </div>
    </details>
  )}

  <button id="clear-filters" class="clear-filters" style="display: none;">{labels.clear}</button>
</nav>

<script>
  function initFilters() {
    const clearBtn = document.getElementById('clear-filters');
    const notesGrid = document.getElementById('notes-grid');
    const noNotesMessage = document.getElementById('no-notes-message');

    if (!notesGrid) return;

    const notes = Array.from(notesGrid.querySelectorAll('.note-card')) as HTMLElement[];

    let activeCategory = 'all';
    let activeTags = new Set<string>();

    function updateFilters() {
      let visibleCount = 0;

      notes.forEach(note => {
        const category = note.dataset.category;
        const noteTags = note.dataset.tags?.split(',') || [];

        const categoryMatch = activeCategory === 'all' || category === activeCategory;
        const tagsMatch = activeTags.size === 0 || Array.from(activeTags).every(tag => noteTags.includes(tag));

        if (categoryMatch && tagsMatch) {
          note.style.display = '';
          visibleCount++;
        } else {
          note.style.display = 'none';
        }
      });

      if (noNotesMessage) {
        noNotesMessage.style.display = visibleCount === 0 ? 'block' : 'none';
      }

      if (clearBtn) {
        clearBtn.style.display = (activeCategory !== 'all' || activeTags.size > 0) ? 'block' : 'none';
      }
    }

    document.querySelectorAll<HTMLElement>('.filter-item').forEach(btn => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.filter;
        const value = btn.dataset.value;

        if (type === 'category') {
          activeCategory = value!;
          document.querySelectorAll<HTMLElement>('.filter-item[data-filter="category"]').forEach(b => {
            b.classList.toggle('active', b.dataset.value === activeCategory);
          });
        } else if (type === 'tag') {
          if (activeTags.has(value!)) {
            activeTags.delete(value!);
            btn.classList.remove('active');
          } else {
            activeTags.add(value!);
            btn.classList.add('active');
          }
        }

        updateFilters();
      });
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        activeCategory = 'all';
        activeTags.clear();

        document.querySelectorAll<HTMLElement>('.filter-item').forEach(btn => {
          btn.classList.toggle('active', btn.dataset.filter === 'category' && btn.dataset.value === 'all');
        });

        updateFilters();
      });
    }
  }

  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>

<style>
  .notes-filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  /* ── Collapsible section ── */
  .filter-section {
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .filter-section:last-of-type {
    border-bottom: none;
    margin-bottom: 0;
  }

  .filter-section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
    padding: var(--space-1) 0;
    user-select: none;
    outline: none;
  }

  /* Remove default marker in all browsers */
  .filter-section-header::-webkit-details-marker { display: none; }
  .filter-section-header::marker { display: none; }

  .filter-section-header:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .filter-section-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .chevron {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  /* Rotate chevron when collapsed */
  .filter-section:not([open]) .chevron {
    transform: rotate(-90deg);
  }

  /* ── Filter items ── */
  .filter-items {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding-top: var(--space-2);
  }

  .filter-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-1) var(--space-2);
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    cursor: pointer;
    text-align: left;
    color: var(--text-muted);
    transition: background var(--duration-fast) var(--ease-out),
                color var(--duration-fast) var(--ease-out);
    gap: var(--space-2);
  }

  .filter-item:hover {
    background: var(--surface-high);
    color: var(--text);
  }

  .filter-item.active {
    background: var(--accent-dim);
    color: var(--accent);
  }

  .filter-item.active .item-count {
    color: var(--accent);
  }

  .item-label {
    font-size: var(--text-sm);
    flex: 1;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .item-count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    flex-shrink: 0;
    min-width: 1.25rem;
    text-align: right;
  }

  .item-tag-prefix {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    flex-shrink: 0;
    opacity: 0.7;
  }

  .filter-item.active .item-tag-prefix {
    opacity: 1;
  }

  /* ── Clear button ── */
  .clear-filters {
    margin-top: var(--space-4);
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-muted);
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    width: 100%;
    text-align: center;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }

  .clear-filters:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>
