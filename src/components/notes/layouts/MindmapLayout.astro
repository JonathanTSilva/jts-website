---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../../../lib/content/locale';
import BackToTop from '../../site/BackToTop.astro';
import ShareButtons from '../../site/ShareButtons.astro';
import { getNoteAccentColor } from '../../../lib/notes';

interface Props {
  note: CollectionEntry<'notes'>;
  Content: any;
  locale: Locale;
}

const { note, Content, locale } = Astro.props;

const t = locale === 'en'
  ? { back: '← Back to notes', backHref: '/notes', depthLegend: ['Root', 'Branch', 'Sub-branch', 'Leaf'] }
  : { back: '← Voltar para notas', backHref: '/pt-br/notes', depthLegend: ['Raiz', 'Ramo', 'Sub-ramo', 'Folha'] };

const accent = getNoteAccentColor(note.data.colorToken, note.data.category);
---

<article class="mindmap-page" style={`--note-accent: ${accent}`}>
  <a href={t.backHref} class="back-link">{t.back}</a>

  <h1 class="note-title">{note.data.title}</h1>

  {note.data.tags && note.data.tags.length > 0 && (
    <div class="note-tags">
      {note.data.tags.map((tag: string) => <span class="tag-pill">#{tag}</span>)}
    </div>
  )}

  <time class="note-date" datetime={note.data.publishedAt.toISOString()}>
    {note.data.publishedAt.toLocaleDateString(locale === 'en' ? 'en-US' : 'pt-BR', { dateStyle: 'long' })}
  </time>

  <div class="mindmap-wrapper">
    <Content />
  </div>

  <ShareButtons title={note.data.title} url={Astro.url.href} type="note" locale={locale as 'en' | 'pt-br'} />
</article>

<BackToTop />

<style>
  .mindmap-page {
    max-width: var(--wide-max);
    margin: 0 auto;
    padding: var(--space-10) var(--space-6);
  }

  .back-link {
    display: block;
    color: var(--text-muted);
    font-size: var(--text-sm);
    text-decoration: none;
    margin-bottom: var(--space-6);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .back-link:hover { color: var(--note-accent); }

  .note-title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  .note-tags { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-3); }
  .tag-pill {
    display: inline-block;
    background: var(--surface-high);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .note-date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }

  /* ── Mindmap container ── */
  .mindmap-wrapper {
    overflow-x: auto;
    padding: var(--space-6) 0 var(--space-8);
    --mm-line: color-mix(in srgb, var(--note-accent) 35%, var(--border));
  }

  /* ── Tree root list ── */
  .mindmap-wrapper :global(.mindmap-tree) {
    list-style: none;
    padding: var(--space-2);
    margin: 0;
    display: inline-flex;
  }

  /* ── Every node: horizontal flex (label → children) ── */
  .mindmap-wrapper :global(.mindmap-node) {
    list-style: none;
    display: flex;
    align-items: center;
  }

  /* ── Root node ── */
  .mindmap-wrapper :global(.mindmap-root > .mindmap-label) {
    display: inline-flex;
    align-items: center;
    background: var(--note-accent);
    color: #fff;
    font-size: var(--text-lg);
    font-weight: 700;
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-full);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--note-accent) 35%, transparent);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── All children containers ── */
  .mindmap-wrapper :global(.mindmap-children) {
    list-style: none;
    display: flex;
    flex-direction: column;
    position: relative;
    padding: 0;
    margin: 0 0 0 1.75rem;
  }

  /* Horizontal bridge from parent label to vertical spine */
  .mindmap-wrapper :global(.mindmap-children)::before {
    content: '';
    position: absolute;
    left: -1.75rem;
    top: 50%;
    width: 1.75rem;
    border-top: 2px solid var(--mm-line);
  }

  /* ── Each child in a children list ── */
  .mindmap-wrapper :global(.mindmap-children > .mindmap-node) {
    position: relative;
    padding: var(--space-1) 0 var(--space-1) 1.25rem;
  }

  /* Horizontal connector: vertical spine → label */
  .mindmap-wrapper :global(.mindmap-children > .mindmap-node)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1.25rem;
    border-top: 2px solid var(--mm-line);
  }

  /* Vertical spine segment (each node draws its portion) */
  .mindmap-wrapper :global(.mindmap-children > .mindmap-node)::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    border-left: 2px solid var(--mm-line);
  }

  /* First child: vertical starts at center */
  .mindmap-wrapper :global(.mindmap-children > .mindmap-node:first-child)::after {
    top: 50%;
    height: 50%;
  }

  /* Last child: vertical ends at center */
  .mindmap-wrapper :global(.mindmap-children > .mindmap-node:last-child)::after {
    height: 50%;
  }

  /* Only child: no vertical spine */
  .mindmap-wrapper :global(.mindmap-children > .mindmap-node:only-child)::after {
    display: none;
  }

  /* ──── Label styles per depth ──── */

  /* Branch (depth 1) — accent-tinted pill */
  .mindmap-wrapper :global(.mindmap-node[data-depth="1"] > .mindmap-label) {
    display: inline-flex;
    align-items: center;
    background: color-mix(in srgb, var(--note-accent) 12%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--note-accent) 25%, var(--border));
    color: var(--text);
    font-weight: 600;
    font-size: var(--text-base);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    white-space: nowrap;
    flex-shrink: 0;
    transition: box-shadow var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }

  .mindmap-wrapper :global(.mindmap-node[data-depth="1"]:hover > .mindmap-label) {
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--note-accent) 18%, transparent);
    border-color: color-mix(in srgb, var(--note-accent) 50%, var(--border));
  }

  /* Sub-branch (depth 2) — dot + text */
  .mindmap-wrapper :global(.mindmap-node[data-depth="2"] > .mindmap-label) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--text);
    padding: 2px 0;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mindmap-wrapper :global(.mindmap-node[data-depth="2"] > .mindmap-label)::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--note-accent) 55%, var(--bg));
    flex-shrink: 0;
  }

  /* Leaf (depth 3+) — small muted text */
  .mindmap-wrapper :global(.mindmap-node[data-depth="3"] > .mindmap-label),
  .mindmap-wrapper :global(.mindmap-node[data-depth="4"] > .mindmap-label) {
    font-size: var(--text-xs);
    color: var(--text-muted);
    padding: 1px 0;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Taper deeper levels ── */
  .mindmap-wrapper :global(.mindmap-node[data-depth="2"] > .mindmap-children),
  .mindmap-wrapper :global(.mindmap-node[data-depth="3"] > .mindmap-children) {
    margin-left: 1.25rem;
  }
  .mindmap-wrapper :global(.mindmap-node[data-depth="2"] > .mindmap-children)::before,
  .mindmap-wrapper :global(.mindmap-node[data-depth="3"] > .mindmap-children)::before {
    left: -1.25rem;
    width: 1.25rem;
  }
  .mindmap-wrapper :global(.mindmap-node[data-depth="2"] > .mindmap-children > .mindmap-node),
  .mindmap-wrapper :global(.mindmap-node[data-depth="3"] > .mindmap-children > .mindmap-node) {
    padding-left: 1rem;
  }
  .mindmap-wrapper :global(.mindmap-node[data-depth="2"] > .mindmap-children > .mindmap-node)::before,
  .mindmap-wrapper :global(.mindmap-node[data-depth="3"] > .mindmap-children > .mindmap-node)::before {
    width: 1rem;
  }
</style>
