---
import TranslationFallbackNotice from '../../site/TranslationFallbackNotice.astro';
import MermaidRenderer from '../../site/MermaidRenderer.astro';
import NoteLayoutWrapper, { type NoteLayoutProps } from './NoteLayoutWrapper.astro';

type Props = NoteLayoutProps;

const { note, Content, locale, prev, next, relatedNotes } = Astro.props;

const fallbackNotice = locale === 'en'
  ? 'This note is not available in English. Showing the original version.'
  : 'Esta nota não está disponível em Português. Mostrando a versão original.';

const isTranslationFallback = note.data.language !== locale;
const dateLocale = locale === 'en' ? 'en-US' : 'pt-BR';
---

<NoteLayoutWrapper
  note={note}
  Content={Content}
  locale={locale}
  prev={prev}
  next={next}
  relatedNotes={relatedNotes}
  articleClass="container note-page"
>
  {note.data.category && (
    <span class="note-category-badge">{note.data.category}</span>
  )}

  <h1 class="note-title">{note.data.title}</h1>

  {note.data.summary && (
    <p class="note-subtitle">{note.data.summary}</p>
  )}

  <div class="note-meta">
    <time class="note-date" datetime={note.data.publishedAt.toISOString()}>
      {note.data.publishedAt.toLocaleDateString(dateLocale, { dateStyle: 'long' })}
    </time>
  </div>

  {note.data.tags && note.data.tags.length > 0 && (
    <div class="note-tags">
      {note.data.tags.map((tag: string) => <span class="tag-pill">#{tag}</span>)}
    </div>
  )}

  <hr class="preamble-divider" />

  {isTranslationFallback && (
    <TranslationFallbackNotice message={fallbackNotice} />
  )}

  <div class="note-content prose">
    <Content />
  </div>

  <Fragment slot="after">
    {note.body?.includes('```mermaid') && <MermaidRenderer />}
  </Fragment>
</NoteLayoutWrapper>

<style>
  .note-page {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-10) var(--space-6);
  }

  .note-category-badge {
    display: inline-block;
    background: color-mix(in srgb, var(--note-accent) 12%, var(--surface));
    color: var(--note-accent);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
  }

  .note-title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-3);
  }

  .note-subtitle {
    font-size: var(--text-lg);
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }

  .note-meta {
    margin-bottom: var(--space-4);
  }

  .note-date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .tag-pill {
    display: inline-block;
    background: var(--surface-high);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .preamble-divider {
    border: none;
    border-top: 1px solid var(--note-accent);
    margin: var(--space-6) 0;
    opacity: 0.5;
  }

  .note-content {
    margin-bottom: var(--space-10);
  }

  .note-content.prose {
    line-height: 1.6;
  }

  .note-content.prose :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .note-content.prose :global(p) {
    margin-bottom: var(--space-4);
  }

  .note-content.prose :global(ul) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }
</style>
