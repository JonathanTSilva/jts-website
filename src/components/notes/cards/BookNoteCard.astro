---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../../../lib/content/locale';
import { contentLocalePath } from '../../../lib/content/locale';
import { getNoteAccentColor } from '../../../lib/notes';
import TranslationStatusTag from '../../site/TranslationStatusTag.astro';

interface Props {
  note: CollectionEntry<'notes'> & { isTranslationMissing?: boolean };
  locale: Locale;
  translationMissingLabel: string;
}

const { note, locale, translationMissingLabel } = Astro.props;

const statusKey = note.data.status?.[0] as 'finished' | 'reading' | 'abandoned' | undefined;
const statusLabel = statusKey
  ? ({ finished: locale === 'en' ? 'Finished' : 'Concluído', reading: locale === 'en' ? 'Reading' : 'Lendo', abandoned: locale === 'en' ? 'Abandoned' : 'Abandonado' }[statusKey] ?? statusKey)
  : undefined;
---

<article
  class="note-card book-note-card"
  data-category={note.data.category || 'uncategorized'}
  data-tags={note.data.tags.join(',')}
  data-type="book"
  style={`border-top: 3px solid ${getNoteAccentColor(note.data.colorToken, note.data.category)}`}
>
  <a href={contentLocalePath(locale, `/notes/${note.data.slug}`)} class="note-link">
    <header class="note-header">
      {note.data.category && <span class="note-category">{note.data.category}</span>}
      <span class="type-badge" aria-label="Book note">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
      </span>
    </header>

    <div class="book-card-inner">
      {note.data.cover && (
        <img src={note.data.cover} alt="" class="book-card-cover" loading="lazy" aria-hidden="true" />
      )}
      <div class="book-card-body">
        <h2 class="note-title">{note.data.title}</h2>
        {note.isTranslationMissing && (
          <TranslationStatusTag text={translationMissingLabel} />
        )}
        <div class="book-card-footer">
          {note.data.author && note.data.author.length > 0 && (
            <span class="book-card-author">{note.data.author.join(', ')}</span>
          )}
          {statusLabel && (
            <span class="book-card-status" data-status={statusKey}>{statusLabel}</span>
          )}
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  .note-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--card-padding);
    transition: transform var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
    position: relative;
    overflow: hidden;
  }
  .note-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-hover);
  }
  .note-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .note-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .note-category {
    text-transform: uppercase;
    font-weight: var(--weight-bold);
    letter-spacing: 0.05em;
    color: var(--accent-hover);
  }
  .type-badge { color: var(--text-muted); display: flex; align-items: center; }
  .book-card-inner {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-3);
    align-items: stretch;
    flex: 1;
  }
  .book-card-inner:not(:has(.book-card-cover)) {
    grid-template-columns: 1fr;
  }
  .book-card-cover {
    width: 3rem;
    border-radius: var(--radius-sm);
    object-fit: cover;
    box-shadow: var(--shadow-sm);
    align-self: start;
  }
  .book-card-body {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .note-title {
    font-size: var(--text-base);
    margin: 0 0 var(--space-2) 0;
    line-height: 1.3;
    flex: 1;
  }
  .book-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
    margin-top: auto;
  }
  .book-card-author {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: var(--font-mono);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .book-card-status {
    flex-shrink: 0;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    white-space: nowrap;
  }
  .book-card-status[data-status="finished"] { background: color-mix(in srgb, #22c55e 15%, var(--surface)); color: #22c55e; }
  .book-card-status[data-status="reading"]  { background: color-mix(in srgb, #f59e0b 15%, var(--surface)); color: #f59e0b; }
  .book-card-status[data-status="abandoned"]{ background: color-mix(in srgb, #ef4444 15%, var(--surface)); color: #ef4444; }
</style>
