---
import type { Publication } from '../../content/portfolio/types';

import type { Locale } from '../../lib/content/locale';

interface Props {
  publication: Publication;
  locale: Locale;
}

const { publication, locale } = Astro.props;
---

<div class="pub-item">
  <span class="pub-date">{publication.date}</span>
  <div class="pub-info">
    <span class="pub-type">{publication.type}</span>
    <h3>
      {publication.link ? (
        <a href={publication.link} target="_blank" rel="noopener noreferrer">{publication.title[locale]}</a>
      ) : (
        publication.title[locale]
      )}
    </h3>
    <span class="pub-publisher">{publication.publisher}</span>
  </div>
</div>

<style>
  .pub-item {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: var(--space-4);
  }

  .pub-date {
    font-family: var(--font-mono);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .pub-type {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-1);
    font-weight: var(--weight-medium);
  }

  .pub-info h3 {
    margin: 0 0 var(--space-1);
    font-size: var(--text-lg);
    line-height: var(--leading-tight);
  }

  .pub-info a {
    color: var(--accent);
    text-decoration: none;
  }

  .pub-info a:hover {
    text-decoration: underline;
  }

  .pub-publisher {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .pub-item {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
