---
import type { Project } from '../../content/portfolio/types';

interface Props {
  project: Project;
  locale: 'en' | 'pt-br';
}

const { project, locale } = Astro.props;
---

<article class="card">
  <div class="card-header">
    <h3>{project.title[locale]}</h3>
    <span class="year">{project.year}</span>
  </div>
  {project.role && <p class="role">{project.role[locale]}</p>}
  <p>{project.description[locale]}</p>
  <div class="tags">
    {project.tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <div class="card-links">
    {project.github && <a href={project.github} class="link-button">GitHub</a>}
    {project.link && <a href={project.link} class="link-button">Website</a>}
  </div>
</article>

<style>
  .card {
    padding: var(--space-6);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .card h3 {
    margin: 0;
    font-size: var(--text-lg);
    line-height: 1.2;
  }

  .year {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .role {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent);
    margin: 0;
  }

  .card p {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    font-size: var(--text-xs);
    background: var(--accent-dim);
    color: var(--accent);
    padding: var(--space-1) var(--space-2);
    border-radius: 4px;
    font-weight: 500;
  }

  .card-links {
    margin-top: auto;
    display: flex;
    gap: var(--space-4);
    padding-top: var(--space-2);
  }
</style>
