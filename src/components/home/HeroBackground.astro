---
const cpuX = 600;
const cpuY = 100;

const leftTraces = [
  { d: `M 0 150 H 300 V ${cpuY + 20} H ${cpuX - 40}`, delay: '0s' },
  { d: `M 0 300 H 400 V ${cpuY + 40} H ${cpuX - 40}`, delay: '1.2s' },
  { d: `M 0 450 H 500 V ${cpuY + 60} H ${cpuX - 40}`, delay: '0.5s' },
];

const rightTraces = [
  { d: `M 1200 150 H 900 V ${cpuY + 20} H ${cpuX + 40}`, delay: '0.8s' },
  { d: `M 1200 300 H 800 V ${cpuY + 40} H ${cpuX + 40}`, delay: '1.5s' },
  { d: `M 1200 450 H 700 V ${cpuY + 60} H ${cpuX + 40}`, delay: '0.3s' },
];

const bottomTraces = [
  { d: `M ${cpuX - 15} ${cpuY + 70} V 500`, delay: '2s' },
  { d: `M ${cpuX} ${cpuY + 70} V 500`, delay: '2.4s' },
  { d: `M ${cpuX + 15} ${cpuY + 70} V 500`, delay: '2.2s' },
];

const allTraces = [...leftTraces, ...rightTraces, ...bottomTraces];
---

<svg class="hero-paths" viewBox="0 0 1200 500" preserveAspectRatio="xMidYMin slice" aria-hidden="true">
  <defs>
    <linearGradient id="pulse-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="transparent" />
      <stop offset="50%"  stop-color="var(--accent)" stop-opacity="1" />
      <stop offset="100%" stop-color="transparent" />
    </linearGradient>

    <linearGradient id="cpu-text-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="var(--text-muted)" />
      <stop offset="50%"  stop-color="white" />
      <stop offset="100%" stop-color="var(--text-muted)" />
    </linearGradient>
  </defs>

  {allTraces.map(t => (
    <path d={t.d} class="trace-base" />
  ))}

  {allTraces.map(t => (
    <path d={t.d} class="trace-pulse" style={`animation-delay: ${t.delay}`} />
  ))}

  <g class="cpu-group" transform={`translate(${cpuX - 50}, ${cpuY})`}>
    <rect width="100" height="70" rx="4" class="cpu-body" />
    <text x="50" y="42" text-anchor="middle" class="cpu-text">CPU</text>
    <path d="M -5 15 h 5 M -5 35 h 5 M -5 55 h 5" stroke="var(--accent)" stroke-width="2" />
    <path d="M 100 15 h 5 M 100 35 h 5 M 100 55 h 5" stroke="var(--accent)" stroke-width="2" />
  </g>
</svg>

<style>
  .hero-paths {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .trace-base {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    opacity: 0.12;
  }

  .trace-pulse {
    fill: none;
    stroke: url(#pulse-grad);
    stroke-width: 2;
    stroke-dasharray: 100 1000;
    stroke-dashoffset: 1100;
    animation: flow 4s linear infinite;
    opacity: 0.8;
  }

  @keyframes flow {
    0%   { stroke-dashoffset: 1100; }
    100% { stroke-dashoffset: 0; }
  }

  .cpu-body {
    fill: #121212;
    stroke: var(--accent);
    stroke-width: 1;
    filter: drop-shadow(0 0 8px var(--accent));
    animation: breathe 3s ease-in-out infinite alternate;
  }

  @keyframes breathe {
    from { opacity: 0.8; filter: drop-shadow(0 0 4px var(--accent)); }
    to   { opacity: 1;   filter: drop-shadow(0 0 12px var(--accent)); }
  }

  .cpu-text {
    font-family: var(--font-mono);
    font-weight: bold;
    font-size: 14px;
    fill: url(#cpu-text-grad);
  }

  @media (max-width: 48rem) {
    .hero-paths { opacity: 0.5; }
  }

  @media (prefers-reduced-motion: reduce) {
    .trace-pulse { animation: none; opacity: 0; }
    .cpu-body    { animation: none; }
  }
</style>
