---
/**
 * HeroBackground.astro
 * Completed PCB board with synchronized unit-based routing for all sides.
 */

// 1. LOCKED CPU GEOMETRY
const cpuX  = 600;
const cpuY  = 30;
const cpuW  = 160;
const cpuH  = 28;
const cxL   = cpuX - cpuW / 2;
const cxR   = cpuX + cpuW / 2;
const cyT   = cpuY;
const cyB   = cpuY + cpuH;
const r     = 15;

const pinL  = cxL - 6;
const pinR  = cxR + 6;
const pinB  = cyB + 6;
const pinT  = cyT - 6;

const lyA = cyT + 7;
const lyB = cyT + 14;
const lyC = cyT + 21;

const bxA = cxL + 15;
const bxB = cxL + 35;
const bxC = cpuX;
const bxD = cxR - 35;
const bxE = cxR - 15;

const q = (cx: number, cy: number, ex: number, ey: number) => `Q ${cx} ${cy} ${ex} ${ey}`;

const u = 30; // Unit size locked

// --- PATH HELPERS ---

function trT_Standard(x0: number, y0: number, xPin: number, yPin: number): string {
  const dir = x0 <= xPin ? 1 : -1;
  return `M ${x0} ${y0} V ${yPin - r} ${q(x0, yPin, x0 + (r * dir), yPin)} H ${xPin}`;
}

// Left Helpers
function trL_1(xEnd: number, y: number): string { return `M ${pinL} ${y} H ${xEnd}`; }
function trL_2(yStart: number): string {
  const x0 = pinL; const y0 = yStart;
  const x1 = x0 - (u * 2); const y1 = y0 + (u * 2);
  const x2 = x1 - (u * 4); const y2 = y1 + (u * 6);
  return `M ${x0} ${y0} H ${x1+r} ${q(x1,y0,x1,y0+r)} V ${y1-r} ${q(x1,y1,x1-r,y1)} H ${x2+r} ${q(x2,y1,x2,y1+r)} V ${y2}`;
}
function trL_3(yStart: number): string {
  const x0 = pinL; const y0 = yStart;
  const x1 = x0 - (u * 1.5); const y1 = y0 + (u * 4);
  const x2 = x1 - (u * 3); const y2 = y1 + (u * 3);
  return `M ${x0} ${y0} H ${x1+r} ${q(x1,y0,x1,y0+r)} V ${y1-r} ${q(x1,y1,x1-r,y1)} H ${x2+r} ${q(x2,y1,x2,y1+r)} V ${y2}`;
}

// Bottom Helpers
function trB_1(xStart: number): string {
  const y0 = pinB; const x0 = xStart;
  const y1 = y0 + (u * 4); const x1 = x0 - (u * 1); const y2 = y1 + (u * 2);
  return `M ${x0} ${y0} V ${y1-r} ${q(x0,y1,x0-r,y1)} H ${x1+r} ${q(x1,y1,x1,y1+r)} V ${y2}`;
}
function trB_2(xStart: number): string {
  const y0 = pinB; const x0 = xStart;
  const y1 = y0 + (u * 8); const x1 = x0 - (u * 4);
  const y2 = y1 + (u * 3); const x2 = x1 + (u * 3); const y3 = y2 - (u * 1);
  return `M ${x0} ${y0} V ${y1-r} ${q(x0,y1,x0-r,y1)} H ${x1+r} ${q(x1,y1,x1,y1+r)} V ${y2-r} ${q(x1,y2,x1+r,y2)} H ${x2-r} ${q(x2,y2,x2,y2-r)} V ${y3}`;
}
function trB_3(xStart: number): string { return `M ${xStart} ${pinB} V ${pinB + (u * 12)}`; }
function trB_4(xStart: number): string {
  const y0 = pinB; const x0 = xStart;
  const y1 = y0 + (u * 5); const x1 = x0 + (u * 3);
  const y2 = y1 + (u * 4); const x2 = x1 - (u * 2);
  return `M ${x0} ${y0} V ${y1-r} ${q(x0,y1,x0+r,y1)} H ${x1-r} ${q(x1,y1,x1,y1+r)} V ${y2-r} ${q(x1,y2,x1-r,y2)} H ${x2}`;
}
function trB_5(xStart: number): string {
  const y0 = pinB; const x0 = xStart;
  const y1 = y0 + (u * 3); const x1 = x0 + (u * 3); const y2 = y1 + (u * 8);
  return `M ${x0} ${y0} V ${y1-r} ${q(x0,y1,x0+r,y1)} H ${x1-r} ${q(x1,y1,x1,y1+r)} V ${y2}`;
}

// --- NEW RIGHT TRACE HELPERS ---

/** * RIGHT 1: 5u right */
function trR_1(y: number): string {
  return `M ${pinR} ${y} H ${pinR + (u * 5)}`;
}

/** * RIGHT 2: 6u right -> 12u down */
function trR_2(yStart: number): string {
  const x0 = pinR; const y0 = yStart;
  const x1 = x0 + (u * 6); const y1 = y0 + (u * 9);
  return `M ${x0} ${y0} H ${x1-r} ${q(x1,y0,x1,y0+r)} V ${y1}`;
}

/** * RIGHT 3: 3u right -> 2u down -> 3u right */
function trR_3(yStart: number): string {
  const x0 = pinR; const y0 = yStart;
  const x1 = x0 + (u * 1); const y1 = y0 + (u * 1.5); const x2 = x1 + (u * 3);
  return `M ${x0} ${y0} H ${x1-r} ${q(x1,y0,x1,y0+r)} V ${y1-r} ${q(x1,y1,x1+r,y1)} H ${x2}`;
}

const traces = [
  // Top
  { sx: bxB - 100, sy: 10, d: trT_Standard(bxB - 100, 10, bxB, pinT), delay: '3.2s' },
  { sx: bxD + 180, sy: 10, d: trT_Standard(bxD + 180, 10, bxD, pinT), delay: '3.8s' },

  // Left
  { sx: 350, sy: lyA, d: trL_1(350, lyA), delay: '0.0s' },
  { sx: pinL - (u*6), sy: lyB + (u*8), d: trL_2(lyB), delay: '2.5s' },
  { sx: pinL - (u*4.5), sy: lyC + (u*7), d: trL_3(lyC), delay: '1.2s' },

  // Bottom
  { sx: bxA - (u*1), sy: pinB + (u*6), d: trB_1(bxA), delay: '1.0s' },
  { sx: bxB - (u*1), sy: pinB + (u*10), d: trB_2(bxB), delay: '2.0s' },
  { sx: bxC, sy: pinB + (u*12), d: trB_3(bxC), delay: '0.3s' },
  { sx: bxD + (u*1), sy: pinB + (u*9), d: trB_4(bxD), delay: '1.5s' },
  { sx: bxE + (u*3), sy: pinB + (u*11), d: trB_5(bxE), delay: '2.8s' },

  // Right
  { sx: pinR + (u*5), sy: lyA, d: trR_1(lyA), delay: '0.7s' },
  { sx: pinR + (u*6), sy: lyB + (u*9), d: trR_2(lyB), delay: '3.1s' },
  { sx: pinR + (u*4), sy: lyC + (u*1.5), d: trR_3(lyC), delay: '1.8s' },
];

const words = ['Cybersecurity','Embedded','Software','AI','Automation','Networking','Architecture','Engineer','Data'];
---

<svg class="hero-paths" viewBox="0 0 1200 500" preserveAspectRatio="xMidYMin slice" aria-hidden="true">
  <defs>
    <linearGradient id="pulse-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="transparent" />
      <stop offset="50%"  stop-color="var(--accent)" stop-opacity="1" />
      <stop offset="100%" stop-color="transparent" />
    </linearGradient>
  </defs>

  {traces.map(t => (
    <g>
      <circle cx={t.sx} cy={t.sy} r="3.5" class="start-dot" />
      <path d={t.d} class="trace-base" />
      <path d={t.d} class="trace-pulse" style={`animation-delay: ${t.delay}`} />
    </g>
  ))}

  <g class="cpu-group" transform={`translate(${cxL}, ${cyT})`}>
    <rect width={cpuW} height={cpuH} rx="3" class="cpu-body" />
    <path d="M 35 0 v -6 M 125 0 v -6" class="cpu-pins" />
    <path d={`M -6 7 h 6 M -6 ${cpuH/2} h 6 M -6 ${cpuH-7} h 6`} class="cpu-pins" />
    <path d={`M ${cpuW} 7 h 6 M ${cpuW} ${cpuH/2} h 6 M ${cpuW} ${cpuH-7} h 6`} class="cpu-pins" />
    <path d={`M 15 ${cpuH} v 6 M 35 ${cpuH} v 6 M ${cpuW/2} ${cpuH} v 6 M 125 ${cpuH} v 6 M 145 ${cpuH} v 6`} class="cpu-pins" />
    <text id="cpu-word" x={cpuW / 2} y={cpuH / 2 + 4.5} text-anchor="middle" class="cpu-text">{words[0]}</text>
  </g>
</svg>

<style>
  .hero-paths { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
  @media (max-width: 47.9375rem) { .hero-paths { display: none; } }
  .start-dot { fill: none; stroke: var(--accent); stroke-width: 1; opacity: 0.05; }
  .trace-base { fill: none; stroke: var(--accent); stroke-width: 1; opacity: 0.05; }
  .trace-pulse {
    fill: none;
    stroke: url(#pulse-grad);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 80 2000;
    animation: flow 6s linear infinite;
    animation-fill-mode: backwards;
    opacity: 0.15;
  }

  @keyframes flow {
    from { stroke-dashoffset: 2160; }
    to   { stroke-dashoffset: 80; }
  }

  .cpu-body, .cpu-pins {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    opacity: 0.12;
  }

  .cpu-text {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    fill: var(--accent);
    animation: blink-text 4s ease-in-out infinite;
  }

  @keyframes blink-text {
    0%, 100% { opacity: 0.00; }
    20%, 75% { opacity: 0.20; }
  }
</style>

<script is:inline define:vars={{ words }}>
  const textEl = document.getElementById('cpu-word');
  let idx = 0;
  if (textEl) {
    setInterval(() => {
        idx = (idx + 1) % words.length;
        textEl.textContent = words[idx];
    }, 4000);
  }
</script>
