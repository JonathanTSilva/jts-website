---
// CPU box geometry (viewBox: 0 0 1200 500)
const cpuX  = 600;
const cpuY  = 30;
const cpuW  = 160;
const cpuH  = 28;
const cxL   = cpuX - cpuW / 2;   // left chip edge  = 520
const cxR   = cpuX + cpuW / 2;   // right chip edge = 680
const cyT   = cpuY;               // top  = 30
const cyB   = cpuY + cpuH;        // bottom = 58
const r     = 15;                 // corner radius

// Pin tips extend 6 px outside the chip body
const pinL  = cxL - 6;           // left  pin tips x = 514
const pinR  = cxR + 6;           // right pin tips x = 686
const pinB  = cyB + 6;           // bottom pin tips y = 64

// Left pin tip y positions (global): 37, 44, 51
const lyA = cyT +  7;   // 37
const lyB = cyT + 14;   // 44
const lyC = cyT + 21;   // 51

// Bottom pin tip x positions (global): 535, 555, 600, 645, 665
const bxA = cxL + 15;  // 535
const bxB = cxL + 35;  // 555
const bxC = cpuX;      // 600 (center)
const bxD = cxR - 35;  // 645
const bxE = cxR - 15;  // 665

// Q bezier helper
const q = (cx: number, cy: number, ex: number, ey: number) =>
  `Q ${cx} ${cy} ${ex} ${ey}`;

// Trace from anywhere on the left half → CPU left pin tip (pinL, yPin)
// Approaches horizontally from left: right to xT, up to yPin, right to pinL
function trL(x0: number, y0: number, xT: number, yPin: number): string {
  return `M ${x0} ${y0} H ${xT-r} ${q(xT,y0,xT,y0-r)} V ${yPin+r} ${q(xT,yPin,xT+r,yPin)} H ${pinL}`;
}
// Same but with extra horizontal jog (long traces)
function trL2(x0: number, y0: number, xT1: number, yMid: number, xT2: number, yPin: number): string {
  return `M ${x0} ${y0} H ${xT1-r} ${q(xT1,y0,xT1,y0-r)} V ${yMid+r} ${q(xT1,yMid,xT1+r,yMid)} H ${xT2-r} ${q(xT2,yMid,xT2,yMid-r)} V ${yPin+r} ${q(xT2,yPin,xT2+r,yPin)} H ${pinL}`;
}

// Trace from anywhere on the right half → CPU right pin tip (pinR, yPin)
function trR(x0: number, y0: number, xT: number, yPin: number): string {
  return `M ${x0} ${y0} H ${xT+r} ${q(xT,y0,xT,y0-r)} V ${yPin+r} ${q(xT,yPin,xT-r,yPin)} H ${pinR}`;
}
function trR2(x0: number, y0: number, xT1: number, yMid: number, xT2: number, yPin: number): string {
  return `M ${x0} ${y0} H ${xT1+r} ${q(xT1,y0,xT1,y0-r)} V ${yMid+r} ${q(xT1,yMid,xT1-r,yMid)} H ${xT2+r} ${q(xT2,yMid,xT2,yMid-r)} V ${yPin+r} ${q(xT2,yPin,xT2-r,yPin)} H ${pinR}`;
}

// Trace from anywhere in the lower half → CPU bottom pin tip (xPin, pinB)
// Goes up to yT, jogs horizontally to xH, then up to pin tip
function trB(x0: number, y0: number, yT: number, xH: number, xPin: number): string {
  if (x0 <= xPin) {
    return `M ${x0} ${y0} V ${yT+r} ${q(x0,yT,x0+r,yT)} H ${xH-r} ${q(xH,yT,xH,yT-r)} V ${pinB+r} ${q(xH,pinB,xH+r,pinB)} H ${xPin}`;
  } else {
    return `M ${x0} ${y0} V ${yT+r} ${q(x0,yT,x0-r,yT)} H ${xH+r} ${q(xH,yT,xH,yT-r)} V ${pinB+r} ${q(xH,pinB,xH-r,pinB)} H ${xPin}`;
  }
}

// 11 traces: 3 left · 3 right · 5 bottom
// Start points distributed throughout the hero — short, medium, and long paths
const traces: Array<{ sx: number; sy: number; d: string; delay: string }> = [
  // ── Left → CPU left pins (x=514) ─────────────────────────────
  { sx: 0,    sy: 200, d: trL(0,   200, 300,        lyB), delay: '0.0s' }, // medium
  { sx: 0,    sy: 420, d: trL2(0,  420, 140, 270, 390, lyA), delay: '2.5s' }, // long
  { sx: 160,  sy: 320, d: trL(160, 320, 380,        lyC), delay: '1.2s' }, // short

  // ── Right → CPU right pins (x=686) ───────────────────────────
  { sx: 1200, sy: 200, d: trR(1200, 200, 900,            lyB), delay: '0.5s' }, // medium
  { sx: 1200, sy: 420, d: trR2(1200, 420, 1060, 270, 810, lyA), delay: '3.0s' }, // long
  { sx: 1040, sy: 320, d: trR(1040, 320, 820,            lyC), delay: '1.7s' }, // short

  // ── Bottom → CPU bottom pins (y=64) ──────────────────────────
  { sx: 160,  sy: 490, d: trB(160,  490, 340, 460, bxA), delay: '1.0s' }, // long
  { sx: 380,  sy: 460, d: trB(380,  460, 260, 510, bxB), delay: '2.0s' }, // medium
  { sx: 500,  sy: 410, d: trB(500,  410, 260, 570, bxC), delay: '0.3s' }, // short
  { sx: 820,  sy: 460, d: trB(820,  460, 280, 665, bxD), delay: '1.5s' }, // medium
  { sx: 1040, sy: 490, d: trB(1040, 490, 360, 700, bxE), delay: '2.8s' }, // long
];

const words = ['Cybersecurity','Embedded','Software','AI','Automation',
               'Networking','Architecture','Engineer','Data'];
---

<svg
  class="hero-paths"
  viewBox="0 0 1200 500"
  preserveAspectRatio="xMidYMin slice"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="pulse-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="transparent" />
      <stop offset="50%"  stop-color="var(--accent)" stop-opacity="1" />
      <stop offset="100%" stop-color="transparent" />
    </linearGradient>
  </defs>

  <!-- Start-point via circles -->
  {traces.map(t => (
    <circle cx={t.sx} cy={t.sy} r="3.5" class="start-dot" />
  ))}

  <!-- Static base traces -->
  {traces.map(t => (
    <path d={t.d} class="trace-base" />
  ))}

  <!-- Animated pulse overlay -->
  {traces.map(t => (
    <path d={t.d} class="trace-pulse" style={`animation-delay: ${t.delay}`} />
  ))}

  <!-- CPU chip -->
  <g class="cpu-group" transform={`translate(${cxL}, ${cyT})`}>
    <rect width={cpuW} height={cpuH} rx="3" class="cpu-body" />
    <!-- left pins: extend 6 px left at y=7,14,21 (global y=37,44,51) -->
    <path d={`M -6 7 h 6 M -6 ${cpuH/2} h 6 M -6 ${cpuH-7} h 6`}
      class="cpu-pins" />
    <!-- right pins: extend 6 px right (global x=680→686) -->
    <path d={`M ${cpuW} 7 h 6 M ${cpuW} ${cpuH/2} h 6 M ${cpuW} ${cpuH-7} h 6`}
      class="cpu-pins" />
    <!-- bottom pins: extend 6 px down at x=15,35,80,125,145 (global x=535,555,600,645,665) -->
    <path d={`M 15 ${cpuH} v 6 M 35 ${cpuH} v 6 M ${cpuW/2} ${cpuH} v 6 M 125 ${cpuH} v 6 M 145 ${cpuH} v 6`}
      class="cpu-pins" />
    <text id="cpu-word" x={cpuW / 2} y={cpuH / 2 + 4.5}
      text-anchor="middle" class="cpu-text">{words[0]}</text>
  </g>
</svg>

<style>
  .hero-paths {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .start-dot {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    opacity: 0.25;
  }

  .trace-base {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.12;
  }

  .trace-pulse {
    fill: none;
    stroke: url(#pulse-grad);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 80 1200;
    stroke-dashoffset: 1280;
    animation: flow 5s linear infinite;
    opacity: 0.75;
  }

  @keyframes flow {
    to { stroke-dashoffset: 0; }
  }

  .cpu-body {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    animation: blink-box 4s ease-in-out infinite;
  }

  .cpu-pins {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1.5;
    stroke-linecap: round;
    animation: blink-box 4s ease-in-out infinite;
  }

  .cpu-text {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    fill: var(--accent);
    animation: blink-text 4s ease-in-out infinite;
  }

  @keyframes blink-box {
    0%         { opacity: 0.05; }
    20%, 75%   { opacity: 0.30; }
    100%       { opacity: 0.05; }
  }
  @keyframes blink-text {
    0%         { opacity: 0.00; }
    20%, 75%   { opacity: 0.55; }
    100%       { opacity: 0.00; }
  }

  @media (max-width: 48rem) {
    .hero-paths { opacity: 0.5; }
  }

  @media (prefers-reduced-motion: reduce) {
    .trace-pulse            { animation: none; opacity: 0; }
    .cpu-body, .cpu-pins    { animation: none; opacity: 0.20; }
    .cpu-text               { animation: none; opacity: 0.40; }
  }
</style>

<script define:vars={{ words }}>
  const textEl  = document.getElementById('cpu-word');
  const cpuBody = document.querySelector('.cpu-body');
  let idx = 0;

  if (cpuBody && textEl) {
    cpuBody.addEventListener('animationiteration', () => {
      idx = (idx + 1) % words.length;
      textEl.textContent = words[idx];
    });
  }
</script>
