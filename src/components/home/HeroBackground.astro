---
const cpuX = 600;
const cpuY = 20;
const cpuW = 160;
const cpuH = 28;
const cpuMid    = cpuY + cpuH / 2;          // 34 — vertical midline
const cpuBottom = cpuY + cpuH;               // 48
const cpuLeft   = cpuX - cpuW / 2;          // 520
const cpuRight  = cpuX + cpuW / 2;          // 680
const r = 12;                                // corner radius

// Rounded-corner path helpers ------------------------------------------
// L-shape from left edge (0, y0) → right to xT → up to yCPU → right to xEnd
function lTrace(y0: number, xT: number): string {
  return `M 0 ${y0} H ${xT-r} Q ${xT} ${y0} ${xT} ${y0-r} V ${cpuMid+r} Q ${xT} ${cpuMid} ${xT+r} ${cpuMid} H ${cpuLeft}`;
}
// Same with an extra intermediate turn (y0 → yMid horizontal leg first)
function lTrace2(y0: number, xT1: number, yMid: number, xT2: number): string {
  return `M 0 ${y0} H ${xT1-r} Q ${xT1} ${y0} ${xT1} ${y0-r} V ${yMid+r} Q ${xT1} ${yMid} ${xT1+r} ${yMid} H ${xT2-r} Q ${xT2} ${yMid} ${xT2} ${yMid-r} V ${cpuMid+r} Q ${xT2} ${cpuMid} ${xT2+r} ${cpuMid} H ${cpuLeft}`;
}
// Mirror of lTrace for right side
function rTrace(y0: number, xT: number): string {
  return `M 1200 ${y0} H ${xT+r} Q ${xT} ${y0} ${xT} ${y0-r} V ${cpuMid+r} Q ${xT} ${cpuMid} ${xT-r} ${cpuMid} H ${cpuRight}`;
}
function rTrace2(y0: number, xT1: number, yMid: number, xT2: number): string {
  return `M 1200 ${y0} H ${xT1+r} Q ${xT1} ${y0} ${xT1} ${y0-r} V ${yMid+r} Q ${xT1} ${yMid} ${xT1-r} ${yMid} H ${xT2+r} Q ${xT2} ${yMid} ${xT2} ${yMid-r} V ${cpuMid+r} Q ${xT2} ${cpuMid} ${xT2-r} ${cpuMid} H ${cpuRight}`;
}
// Bottom trace: from (x0, cpuBottom) → down to yT → horizontal → down to 500
function bTraceLeft(x0: number, yT: number, xEnd: number): string {
  return `M ${x0} ${cpuBottom} V ${yT-r} Q ${x0} ${yT} ${x0-r} ${yT} H ${xEnd+r} Q ${xEnd} ${yT} ${xEnd} ${yT+r} V 500`;
}
function bTraceRight(x0: number, yT: number, xEnd: number): string {
  return `M ${x0} ${cpuBottom} V ${yT-r} Q ${x0} ${yT} ${x0+r} ${yT} H ${xEnd-r} Q ${xEnd} ${yT} ${xEnd} ${yT+r} V 500`;
}

// Trace definitions -------------------------------------------------------
const traces = [
  // Left — 3 traces connecting to CPU left pin
  { d: lTrace(90, 200),              delay: '0s'   },
  { d: lTrace(240, 350),             delay: '1.2s' },
  { d: lTrace2(390, 80, 280, 460),   delay: '0.5s' },
  // Right — 3 traces connecting to CPU right pin
  { d: rTrace(90, 1000),             delay: '0.8s' },
  { d: rTrace(240, 850),             delay: '1.5s' },
  { d: rTrace2(390, 1120, 280, 740), delay: '0.3s' },
  // Bottom — 3 traces descending from CPU
  { d: bTraceLeft(cpuX - 20, 180, 160),  delay: '2.0s' },
  { d: `M ${cpuX} ${cpuBottom} V 500`,   delay: '2.4s' },
  { d: bTraceRight(cpuX + 20, 180, 1040), delay: '2.2s' },
  // Interior — extra coverage across the full hero area
  { d: `M 0 460 H ${128} Q 140 460 140 ${472} V 500`,                          delay: '0.6s' },
  { d: `M 1200 460 H ${1072} Q 1060 460 1060 ${472} V 500`,                    delay: '1.0s' },
  { d: `M 300 500 V ${432} Q 300 420 ${288} 420 H 0`,                          delay: '1.8s' },
  { d: `M 900 500 V ${432} Q 900 420 ${912} 420 H 1200`,                       delay: '2.6s' },
  { d: `M 150 500 V ${362} Q 150 350 ${138} 350 H 0`,                          delay: '0.9s' },
  { d: `M 1050 500 V ${362} Q 1050 350 ${1062} 350 H 1200`,                    delay: '1.4s' },
];

const words = ['Cybersecurity','Embedded','Software','AI','Automation',
               'Networking','Architecture','Engineer','Data'];
---

<svg
  class="hero-paths"
  viewBox="0 0 1200 500"
  preserveAspectRatio="xMidYMin slice"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="pulse-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="transparent" />
      <stop offset="50%"  stop-color="var(--accent)" stop-opacity="1" />
      <stop offset="100%" stop-color="transparent" />
    </linearGradient>
  </defs>

  <!-- Static base traces -->
  {traces.map(t => (
    <path d={t.d} class="trace-base" />
  ))}

  <!-- Animated pulse overlay -->
  {traces.map(t => (
    <path d={t.d} class="trace-pulse" style={`animation-delay: ${t.delay}`} />
  ))}

  <!-- CPU chip -->
  <g class="cpu-group" transform={`translate(${cpuLeft}, ${cpuY})`}>
    <rect width={cpuW} height={cpuH} rx="4" class="cpu-body" />
    <!-- side pins -->
    <path d={`M -6 8 h 6 M -6 ${cpuH/2} h 6 M -6 ${cpuH-8} h 6`}
      stroke="var(--accent)" stroke-width="1.5" fill="none" />
    <path d={`M ${cpuW} 8 h 6 M ${cpuW} ${cpuH/2} h 6 M ${cpuW} ${cpuH-8} h 6`}
      stroke="var(--accent)" stroke-width="1.5" fill="none" />
    <!-- label — text changed by JS on each blink -->
    <text id="cpu-word" x={cpuW/2} y={cpuH/2 + 5}
      text-anchor="middle" class="cpu-text">{words[0]}</text>
  </g>
</svg>

<style>
  .hero-paths {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .trace-base {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    opacity: 0.12;
  }

  .trace-pulse {
    fill: none;
    stroke: url(#pulse-grad);
    stroke-width: 2;
    stroke-dasharray: 100 1000;
    stroke-dashoffset: 1100;
    animation: flow 4s linear infinite;
    opacity: 0.7;
  }

  @keyframes flow {
    to { stroke-dashoffset: 0; }
  }

  /* CPU box: same low opacity as traces, blinks to reveal each word */
  .cpu-body {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    opacity: 0.06;
    animation: blink-cpu 4s ease-in-out infinite;
  }

  .cpu-text {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    fill: var(--accent);
    opacity: 0;
    animation: blink-cpu 4s ease-in-out infinite;
  }

  /*
   * Keyframes: fade from dim → bright → dim.
   * animationiteration fires at the start of 0% → word is changed then →
   * the new word brightens in immediately.
   */
  @keyframes blink-cpu {
    0%   { opacity: 0.04; }
    20%  { opacity: 0.35; }
    75%  { opacity: 0.35; }
    100% { opacity: 0.04; }
  }

  /* text peaks at slightly lower opacity than box */
  .cpu-text {
    animation: blink-text 4s ease-in-out infinite;
  }
  @keyframes blink-text {
    0%   { opacity: 0.0;  }
    20%  { opacity: 0.55; }
    75%  { opacity: 0.55; }
    100% { opacity: 0.0;  }
  }

  @media (max-width: 48rem) {
    .hero-paths { opacity: 0.5; }
  }

  @media (prefers-reduced-motion: reduce) {
    .trace-pulse { animation: none; opacity: 0; }
    .cpu-body    { animation: none; opacity: 0.2; }
    .cpu-text    { animation: none; opacity: 0.4; }
  }
</style>

<script define:vars={{ words }}>
  const textEl = document.getElementById('cpu-word');
  const cpuBody = document.querySelector('.cpu-body');
  let idx = 0;

  if (cpuBody && textEl) {
    cpuBody.addEventListener('animationiteration', () => {
      idx = (idx + 1) % words.length;
      textEl.textContent = words[idx];
    });
  }
</script>
