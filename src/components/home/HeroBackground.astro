---
// CPU box geometry (viewBox: 0 0 1200 500)
const cpuX  = 600;
const cpuY  = 30;
const cpuW  = 160;
const cpuH  = 28;
const cxL   = cpuX - cpuW / 2;   // left edge  = 520
const cxR   = cpuX + cpuW / 2;   // right edge = 680
const cyT   = cpuY;               // top edge   = 30
const cyB   = cpuY + cpuH;        // bot edge   = 58
const r     = 15;                 // corner radius

// Quadratic bezier helper
const q = (cx: number, cy: number, ex: number, ey: number) =>
  `Q ${cx} ${cy} ${ex} ${ey}`;

// Left traces: start at x=0, route right then up to CPU left perimeter (x=520)
function lL(y0: number, xT: number, yPin: number): string {
  return `M 0 ${y0} H ${xT-r} ${q(xT,y0,xT,y0-r)} V ${yPin+r} ${q(xT,yPin,xT+r,yPin)} H ${cxL}`;
}
function lL2(y0: number, xT1: number, yMid: number, xT2: number, yPin: number): string {
  return `M 0 ${y0} H ${xT1-r} ${q(xT1,y0,xT1,y0-r)} V ${yMid+r} ${q(xT1,yMid,xT1+r,yMid)} H ${xT2-r} ${q(xT2,yMid,xT2,yMid-r)} V ${yPin+r} ${q(xT2,yPin,xT2+r,yPin)} H ${cxL}`;
}

// Right traces: start at x=1200, route left then up to CPU right perimeter (x=680)
function rL(y0: number, xT: number, yPin: number): string {
  return `M 1200 ${y0} H ${xT+r} ${q(xT,y0,xT,y0-r)} V ${yPin+r} ${q(xT,yPin,xT-r,yPin)} H ${cxR}`;
}
function rL2(y0: number, xT1: number, yMid: number, xT2: number, yPin: number): string {
  return `M 1200 ${y0} H ${xT1+r} ${q(xT1,y0,xT1,y0-r)} V ${yMid+r} ${q(xT1,yMid,xT1-r,yMid)} H ${xT2+r} ${q(xT2,yMid,xT2,yMid-r)} V ${yPin+r} ${q(xT2,yPin,xT2-r,yPin)} H ${cxR}`;
}

// Bottom traces: start at y=490, route up to CPU bottom perimeter (y=58)
function bL(x0: number, yT: number, xH: number, xPin: number): string {
  if (x0 <= xPin) {
    return `M ${x0} 490 V ${yT+r} ${q(x0,yT,x0+r,yT)} H ${xH-r} ${q(xH,yT,xH,yT-r)} V ${cyB+r} ${q(xH,cyB,xH+r,cyB)} H ${xPin}`;
  } else {
    return `M ${x0} 490 V ${yT+r} ${q(x0,yT,x0-r,yT)} H ${xH+r} ${q(xH,yT,xH,yT-r)} V ${cyB+r} ${q(xH,cyB,xH-r,cyB)} H ${xPin}`;
  }
}

// 11 traces: 3 left (y-pins 37, 44, 51) · 3 right (y-pins 37, 44, 51) · 5 bottom (x-pins 535, 555, 600, 645, 665)
const traces: Array<{ sx: number; sy: number; d: string; delay: string }> = [
  // ── Left edge → CPU left perimeter ───────────────────────────
  { sx: 0, sy: 100, d: lL(100, 320, 37),                   delay: '0.0s' },
  { sx: 0, sy: 290, d: lL(290, 210, 44),                   delay: '1.5s' },
  { sx: 0, sy: 430, d: lL2(430, 140, 280, 390, 51),        delay: '3.0s' },

  // ── Right edge → CPU right perimeter ─────────────────────────
  { sx: 1200, sy: 100, d: rL(100, 880, 37),                delay: '0.5s' },
  { sx: 1200, sy: 290, d: rL(290, 990, 44),                delay: '2.0s' },
  { sx: 1200, sy: 430, d: rL2(430, 1060, 280, 810, 51),   delay: '3.5s' },

  // ── Bottom area → CPU bottom perimeter ───────────────────────
  { sx: 340, sy: 490, d: bL(340, 340, 460, 535),           delay: '1.0s' },
  { sx: 490, sy: 490, d: bL(490, 260, 540, 555),           delay: '2.5s' },
  { sx: 600, sy: 490, d: `M 600 490 V ${cyB}`,             delay: '0.3s' },
  { sx: 710, sy: 490, d: bL(710, 260, 660, 645),           delay: '1.8s' },
  { sx: 860, sy: 490, d: bL(860, 340, 740, 665),           delay: '2.8s' },
];

const words = ['Cybersecurity','Embedded','Software','AI','Automation',
               'Networking','Architecture','Engineer','Data'];
---

<svg
  class="hero-paths"
  viewBox="0 0 1200 500"
  preserveAspectRatio="xMidYMin slice"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="pulse-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="transparent" />
      <stop offset="50%"  stop-color="var(--accent)" stop-opacity="1" />
      <stop offset="100%" stop-color="transparent" />
    </linearGradient>
  </defs>

  <!-- Start-point circles (vias / pads) -->
  {traces.map(t => (
    <circle cx={t.sx} cy={t.sy} r="3.5" class="start-dot" />
  ))}

  <!-- Static base traces -->
  {traces.map(t => (
    <path d={t.d} class="trace-base" />
  ))}

  <!-- Animated pulse overlay -->
  {traces.map(t => (
    <path d={t.d} class="trace-pulse" style={`animation-delay: ${t.delay}`} />
  ))}

  <!-- CPU chip -->
  <g class="cpu-group" transform={`translate(${cxL}, ${cyT})`}>
    <rect width={cpuW} height={cpuH} rx="3" class="cpu-body" />
    <!-- left pins (y=7, 14, 21 → global y=37, 44, 51) -->
    <path d={`M -6 7 h 6 M -6 ${cpuH/2} h 6 M -6 ${cpuH-7} h 6`}
      class="cpu-pins" />
    <!-- right pins (mirror) -->
    <path d={`M ${cpuW} 7 h 6 M ${cpuW} ${cpuH/2} h 6 M ${cpuW} ${cpuH-7} h 6`}
      class="cpu-pins" />
    <!-- bottom pins (x=15,35,80,125,145 → global x=535,555,600,645,665) -->
    <path d={`M 15 ${cpuH} v 6 M 35 ${cpuH} v 6 M ${cpuW/2} ${cpuH} v 6 M 125 ${cpuH} v 6 M 145 ${cpuH} v 6`}
      class="cpu-pins" />
    <text id="cpu-word" x={cpuW / 2} y={cpuH / 2 + 4.5}
      text-anchor="middle" class="cpu-text">{words[0]}</text>
  </g>
</svg>

<style>
  .hero-paths {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  /* Via / start-point circles */
  .start-dot {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    opacity: 0.25;
  }

  /* Static trace lines */
  .trace-base {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.12;
  }

  /* Moving electricity pulse */
  .trace-pulse {
    fill: none;
    stroke: url(#pulse-grad);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 80 1200;
    stroke-dashoffset: 1280;
    animation: flow 5s linear infinite;
    opacity: 0.75;
  }

  @keyframes flow {
    to { stroke-dashoffset: 0; }
  }

  /* CPU body — blinks to reveal word */
  .cpu-body {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    animation: blink-box 4s ease-in-out infinite;
  }

  .cpu-pins {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1.5;
    stroke-linecap: round;
    animation: blink-box 4s ease-in-out infinite;
  }

  .cpu-text {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    fill: var(--accent);
    animation: blink-text 4s ease-in-out infinite;
  }

  /*
   * 0% = minimum: word just swapped (animationiteration fires here)
   * 20%–75% = bright: new word visible
   * 100% = back to minimum: cycle restarts
   */
  @keyframes blink-box {
    0%         { opacity: 0.05; }
    20%, 75%   { opacity: 0.30; }
    100%       { opacity: 0.05; }
  }
  @keyframes blink-text {
    0%         { opacity: 0.00; }
    20%, 75%   { opacity: 0.55; }
    100%       { opacity: 0.00; }
  }

  @media (max-width: 48rem) {
    .hero-paths { opacity: 0.5; }
  }

  @media (prefers-reduced-motion: reduce) {
    .trace-pulse            { animation: none; opacity: 0; }
    .cpu-body, .cpu-pins    { animation: none; opacity: 0.20; }
    .cpu-text               { animation: none; opacity: 0.40; }
  }
</style>

<script define:vars={{ words }}>
  const textEl  = document.getElementById('cpu-word');
  const cpuBody = document.querySelector('.cpu-body');
  let idx = 0;

  if (cpuBody && textEl) {
    cpuBody.addEventListener('animationiteration', () => {
      idx = (idx + 1) % words.length;
      textEl.textContent = words[idx];
    });
  }
</script>
