---
import { getCollection } from 'astro:content';
import ProjectCard from '../portfolio/ProjectCard.astro';
import { projects } from '../../content/portfolio/projects';
import { publications } from '../../content/portfolio/publications';
import { contentLocalePath } from '../../lib/content/locale';

interface Props {
  locale: 'en' | 'pt-br';
  t: {
    projects: string;
    publications: string;
    blog: string;
    notes: string;
    seeAllPortfolio: string;
    downloadCv: string;
    viewAllBlog: string;
    viewAllNotes: string;
    at: string;
    viewAllPublications: string;
  };
}

const { locale, t } = Astro.props;

// Fetch latest blog posts
const blogPosts = await getCollection('blog', ({ data }) => {
  return data.language === locale;
});
const latestBlogPosts = blogPosts
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 5);

// Fetch latest notes
const notes = await getCollection('notes', ({ data }) => {
  return data.language === locale;
});
const latestNotes = notes
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);

const featuredProjects = projects.filter(p => p.status === 'Featured');
const selectedProjects = featuredProjects.length >= 4
  ? featuredProjects.slice(0, 4)
  : [
      ...featuredProjects,
      ...projects.filter(p => p.status !== 'Featured').slice(0, 4 - featuredProjects.length),
    ];

const projectsLabel = locale === 'pt-br' ? '// portfólio' : '// portfolio';
const publicationsLabel = locale === 'pt-br' ? '// portfólio' : '// portfolio';
const blogLabel = locale === 'pt-br' ? '// blog' : '// blog';
const notesLabel = locale === 'pt-br' ? '// notas' : '// notes';
---

<section class="home-section">
  <header class="section-header">
    <p class="section-label">{projectsLabel}</p>
    <h2 class="section-heading">{t.projects}</h2>
  </header>
  <div class="grid">
    {selectedProjects.map((project) => (
      <ProjectCard project={project} locale={locale} />
    ))}
  </div>
  <div class="cta">
    <a href={contentLocalePath(locale, '/portfolio')} class="btn-primary">{t.seeAllPortfolio}</a>
    <a href="/assets/cv/jonathan-cv.pdf" download class="btn-secondary">{t.downloadCv}</a>
  </div>
</section>

<section class="home-section">
  <header class="section-header">
    <p class="section-label">{publicationsLabel}</p>
    <h2 class="section-heading">{t.publications}</h2>
  </header>
  <div class="pub-card-row">
    {publications.map((pub) => (
      <div class="pub-card">
        <div class="pub-card-top">
          <span class="pub-type-badge">{pub.type}</span>
          <span class="pub-card-date">{pub.date}</span>
        </div>
        <p class="pub-card-title">
          {pub.link
            ? <a href={pub.link} target="_blank" rel="noopener noreferrer">{pub.title[locale]}</a>
            : pub.title[locale]
          }
        </p>
        <div class="pub-card-footer">
          <span class="pub-card-publisher">{pub.publisher}</span>
          {pub.link && (
            <a href={pub.link} class="pub-card-arrow" target="_blank" rel="noopener noreferrer" aria-label="Open publication">→</a>
          )}
        </div>
      </div>
    ))}
  </div>
  <a href={contentLocalePath(locale, '/portfolio')} class="pub-viewall section-viewall">
    {t.viewAllPublications} →
  </a>
</section>

<section class="home-section">
  <header class="section-header">
    <p class="section-label">{blogLabel}</p>
    <h2 class="section-heading">{t.blog}</h2>
  </header>
  <div class="blog-list">
    {latestBlogPosts.map((post) => (
      <a
        href={contentLocalePath(locale, `/blog/${post.id}`)}
        class="blog-preview-row"
      >
        <span class="blog-preview-title">{post.data.title}</span>
        <span class="blog-preview-date">
          {new Date(post.data.publishedAt).toLocaleDateString(locale)}
        </span>
      </a>
    ))}
  </div>
  <a href={contentLocalePath(locale, '/blog')} class="section-viewall">{t.viewAllBlog} →</a>
</section>

<section class="home-section">
  <header class="section-header">
    <p class="section-label">{notesLabel}</p>
    <h2 class="section-heading">{t.notes}</h2>
  </header>
  <div class="notes-grid">
    {latestNotes.map((note) => (
      <a
        href={contentLocalePath(locale, `/notes/${note.id}`)}
        class="note-preview-card"
      >
        <span class="note-preview-date">
          {new Date(note.data.publishedAt).toLocaleDateString(locale)}
        </span>
        <span class="note-preview-title">{note.data.title}</span>
        {note.data.category && (
          <span class="note-category">{note.data.category}</span>
        )}
      </a>
    ))}
  </div>
  <a href={contentLocalePath(locale, '/notes')} class="section-viewall">{t.viewAllNotes} →</a>
</section>

<style>
  .home-section {
    padding-block: var(--space-12);
  }

  .section-header {
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-2);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-1) 0;
  }

  .section-heading {
    font-size: var(--text-2xl);
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  /* Home grid is always 2 columns — never let featured cards span full row */
  .grid :global(.project-card[style*="span"]) {
    grid-column: span 1 !important;
  }

  @media (max-width: 48rem) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .cta {
    margin-top: var(--space-8);
    display: flex;
    gap: var(--space-6);
    align-items: center;
    flex-wrap: wrap;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Publications card row */
  .pub-card-row {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--space-4);
    overflow-x: auto;
    padding-bottom: var(--space-2);
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .pub-card {
    min-width: 16rem;
    max-width: 20rem;
    flex-shrink: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--card-padding);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: box-shadow var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  .pub-card:hover {
    box-shadow: var(--shadow-sm);
    border-color: var(--accent);
  }

  .pub-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .pub-type-badge {
    font-size: var(--text-xs);
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: var(--radius-full);
    padding: 2px var(--space-2);
    font-family: var(--font-mono);
    text-transform: lowercase;
    white-space: nowrap;
  }

  .pub-card-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
  }

  .pub-card-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text);
    margin: 0;
    flex: 1;
    line-height: var(--leading-normal);
  }

  .pub-card-title a {
    color: var(--text);
    text-decoration: none;
  }
  .pub-card-title a:hover { color: var(--accent); text-decoration: none; }

  .pub-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: auto;
  }

  .pub-card-publisher {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .pub-card-arrow {
    color: var(--accent);
    text-decoration: none;
    font-size: var(--text-base);
    flex-shrink: 0;
  }
  .pub-card-arrow:hover { text-decoration: none; }

  /* Blog preview rows */
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .blog-preview-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding-block: var(--space-1);
    text-decoration: none;
    color: var(--text);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .blog-preview-row:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .blog-preview-title {
    flex: 1;
  }

  .blog-preview-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Notes preview cards */
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .note-preview-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--card-padding);
    text-decoration: none;
    color: var(--text);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: box-shadow var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  .note-preview-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
    text-decoration: none;
  }

  .note-preview-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .note-preview-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
  }

  .note-category {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--text-muted);
    margin-top: auto;
  }

  /* View all link */
  .section-viewall {
    display: inline-block;
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
  }

  .section-viewall:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .notes-grid {
      grid-template-columns: 1fr;
    }
    .cta {
      justify-content: center;
    }
  }
</style>
