---
import type { Locale } from '../../lib/content/locale';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const t = {
  en: {
    title: 'Contact',
    email: 'Email',
    linkedin: 'LinkedIn',
    github: 'GitHub',
  },
  'pt-br': {
    title: 'Contato',
    email: 'Email',
    linkedin: 'LinkedIn',
    github: 'GitHub',
  },
}[locale];

const contacts = [
  { label: t.email, href: 'mailto:contact@example.com' },
  { label: t.linkedin, href: 'https://linkedin.com/in/example' },
  { label: t.github, href: 'https://github.com/example' },
];
---

<section class="contact" id="contact">
  <h2>{t.title}</h2>
  <div class="contact-links">
    {contacts.map((contact) => (
      <a href={contact.href} target="_blank" rel="noopener noreferrer">
        {contact.label}
      </a>
    ))}
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-12);
    border-top: 1px solid var(--border);
  }

  h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .contact-links a {
    text-decoration: none;
    color: var(--accent);
    font-weight: 500;
  }

  .contact-links a:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }
</style>
