---
import type { Locale } from '../../lib/content/locale';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const t = {
  en: {
    title: 'Contact',
    label: '// contact',
    email: 'Email',
    linkedin: 'LinkedIn',
    github: 'GitHub',
  },
  'pt-br': {
    title: 'Contato',
    label: '// contato',
    email: 'Email',
    linkedin: 'LinkedIn',
    github: 'GitHub',
  },
}[locale];

const contacts = [
  { label: t.email, href: 'mailto:jonathantosilva@hotmail.com', external: false },
  { label: t.linkedin, href: 'https://www.linkedin.com/in/jonathantsilva/', external: true },
  { label: t.github, href: 'https://github.com/JonathanTSilva', external: true },
];
---

<section class="contact" id="contact">
  <header class="section-header">
    <p class="section-label">{t.label}</p>
    <h2 class="section-heading">{t.title}</h2>
  </header>
  <div class="contact-links">
    {contacts.map((contact) => (
      <a
        href={contact.href}
        class="btn-secondary"
        target={contact.external ? '_blank' : undefined}
        rel={contact.external ? 'noopener noreferrer' : undefined}
      >
        {contact.label}
      </a>
    ))}
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-12);
    border-top: 1px solid var(--border);
  }

  .section-header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-1) 0;
  }

  .section-heading {
    font-size: var(--text-2xl);
    margin: 0;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
</style>
