---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotesGrid from '../../components/notes/NotesGrid.astro';
import NotesFilters from '../../components/notes/NotesFilters.astro';

const locale = 'en';

const translations = {
  en: '/notes',
  'pt-br': '/pt-br/notes',
};

const t = {
  title: 'Notes',
  description: 'A collection of technical notes, cheat sheets, and bits of knowledge.',
};

const allNotes = await getCollection('notes');

// Get all notes for the current locale, and all notes missing a translation in the current locale
const uniqueTranslationKeys = Array.from(new Set(allNotes.map(p => p.data.translationKey)));

const notesToShow = uniqueTranslationKeys.map(key => {
  const translations = allNotes.filter(p => p.data.translationKey === key);
  const currentLocaleNote = translations.find(p => p.data.language === locale);
  if (currentLocaleNote) {
    return { ...currentLocaleNote, isTranslationMissing: false };
  } else {
    // Return the default locale post (or the first one available if default is not there)
    const fallbackNote = translations.find(p => p.data.language === 'en') || translations[0];
    if (!fallbackNote) return null;
    return { ...fallbackNote, isTranslationMissing: true };
  }
}).filter((p): p is NonNullable<typeof p> => p !== null)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const categories = Array.from(new Set(notesToShow.map(note => note.data.category).filter((c): c is string => !!c))).sort();
const tags = Array.from(new Set(notesToShow.flatMap(note => note.data.tags))).sort();
const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = notesToShow.filter(n => n.data.category === cat).length;
  return acc;
}, {} as Record<string, number>);
---

<BaseLayout locale={locale} pageType="notes-index" translations={translations}>
  <header class="page-header">
    <h1 class="page-title">{t.title}</h1>
    <p class="page-description">{t.description}</p>
  </header>

  <div class="notes-layout">
    <aside class="notes-sidebar">
      <NotesFilters categories={categories} categoryCounts={categoryCounts} tags={tags} locale={locale} />
    </aside>
    <div class="notes-content">
      <NotesGrid notes={notesToShow} locale={locale} />
    </div>
  </div>
</BaseLayout>

<style is:global>
  main:has(.notes-layout) {
    max-width: 62rem;
  }
</style>

<style>
  .page-header {
    margin-bottom: var(--space-12);
  }

  .page-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .page-description {
    font-size: var(--text-lg);
    color: var(--text-muted);
  }

  .notes-layout {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .notes-sidebar {
    position: sticky;
    top: var(--space-8);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  @media (max-width: 48rem) {
    .notes-layout {
      grid-template-columns: 1fr;
    }

    .notes-sidebar {
      position: static;
    }
  }
</style>
