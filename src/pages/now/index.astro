---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allEntries = await getCollection('now');
const locale = 'en';

// Find the entry for this locale
let entry = allEntries.find(e => e.data.language === locale);

// Fallback to English if not found (though this is the English page)
if (!entry) {
  entry = allEntries.find(e => e.data.language === 'en');
}

if (!entry) {
  throw new Error('No "now" content found');
}

const { Content } = await render(entry);

const t = {
  lastUpdated: 'Last updated:',
  status: 'Current focus:',
};
---

<BaseLayout 
  locale={locale} 
  title={entry.data.title}
  description={entry.data.summary}
>
  <main class="container">
    <header class="now-header">
      <h1 class="now-title">{entry.data.title}</h1>
      <div class="now-meta">
        {entry.data.updatedAt && (
          <p class="updated-at">
            {t.lastUpdated} <time datetime={entry.data.updatedAt.toISOString()}>
              {entry.data.updatedAt.toLocaleDateString(locale, { dateStyle: 'long' })}
            </time>
          </p>
        )}
        {entry.data.status && (
          <p class="status">
            {t.status} <strong>{entry.data.status}</strong>
          </p>
        )}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </main>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-8) 0;
  }
  .now-header {
    margin-bottom: var(--space-8);
  }
  .now-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }
  .now-meta {
    color: var(--text-muted);
    font-size: var(--text-base);
    border-left: 4px solid var(--border);
    padding-left: var(--space-4);
  }
  .now-meta p {
    margin: 0;
  }
  .prose {
    line-height: 1.6;
  }
  .prose :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }
  .prose :global(p) {
    margin-bottom: var(--space-4);
  }
  .prose :global(ul) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }
  .prose :global(li) {
    margin-bottom: var(--space-2);
  }
</style>
