---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allEntries = await getCollection('now');
const locale = 'pt-br';

// Find the entry for this locale
let entry = allEntries.find(e => e.data.language === locale);
let isTranslationFallback = false;

// Fallback to English if not found
if (!entry) {
  entry = allEntries.find(e => e.data.language === 'en');
  isTranslationFallback = true;
}

if (!entry) {
  throw new Error('No "now" content found');
}

const { Content } = await render(entry);

const translations = {
  en: '/now',
  'pt-br': '/pt-br/now',
};

const t = {
  lastUpdated: 'Última atualização:',
  status: 'Foco atual:',
  fallbackNotice: 'Esta página não está disponível em Português. Mostrando a versão original.',
};
---

<BaseLayout 
  locale={locale} 
  title={entry.data.title}
  description={entry.data.summary}
  translations={translations}
>
  <div class="container">
    <header class="now-header">
      <h1 class="now-title">{entry.data.title}</h1>
      {entry.data.status && (
        <span class="now-status">{entry.data.status}</span>
      )}
      {entry.data.updatedAt && (
        <p class="now-updated">
          {t.lastUpdated} <time datetime={entry.data.updatedAt.toISOString()}>
            {entry.data.updatedAt.toLocaleDateString(locale, { dateStyle: 'long' })}
          </time>
        </p>
      )}
    </header>

    {isTranslationFallback && (
      <div class="fallback-notice">
        <p>{t.fallbackNotice}</p>
      </div>
    )}

    <div class="prose">
      <Content />
    </div>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-8) 0;
  }
  .now-header {
    margin-bottom: var(--space-8);
  }
  .now-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }
  .now-status {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: var(--accent-dim);
    color: var(--accent);
    padding: 2px var(--space-3);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-2);
  }
  .now-updated {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }
  .fallback-notice {
    background-color: var(--surface-high);
    border-left: 4px solid var(--border);
    padding: var(--space-4);
    margin-bottom: var(--space-8);
    color: var(--text-muted);
  }
  .prose {
    line-height: 1.6;
  }
  .prose :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }
  .prose :global(p) {
    margin-bottom: var(--space-4);
  }
  .prose :global(ul) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }
  .prose :global(li) {
    margin-bottom: var(--space-2);
  }
</style>
