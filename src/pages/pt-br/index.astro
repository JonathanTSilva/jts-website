---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/home/Hero.astro';
import HomeSections from '../../components/home/HomeSections.astro';

const locale = 'pt-br';

const translations = {
  en: '/',
  'pt-br': '/pt-br',
};

const t = {
  projects: 'Projetos',
  publications: 'Publicações',
  blog: 'Últimos Posts',
  notes: 'Últimas Notas',
  seeAllPortfolio: 'Ver portfólio completo',
  downloadCv: 'Baixar CV (PDF)',
  viewAllBlog: 'Ver todos os posts',
  viewAllNotes: 'Ver todas as notas',
  at: 'em',
  viewAllPublications: 'Ver todas as publicações',
};
---

<BaseLayout locale={locale} title="Início" translations={translations}>
  <Hero locale="pt-br" />
  <HomeSections locale={locale} t={t} />
</BaseLayout>
