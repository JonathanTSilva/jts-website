---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NotesGrid from '../../../components/notes/NotesGrid.astro';
import NotesFilters from '../../../components/notes/NotesFilters.astro';
import { buildNoteIndex } from '../../../lib/content/staticPaths';

const locale = 'pt-br';

const translations = {
  en: '/notes',
  'pt-br': '/pt-br/notes',
};

const t = {
  title: 'Notas',
  description: 'Uma coleção de notas técnicas, dicas e pedaços de conhecimento.',
};

const allNotes = await getCollection('notes');
const { notesToShow, categories, tags, categoryCounts, noteTypes, noteTypeCounts } = buildNoteIndex(allNotes, locale);
---

<BaseLayout locale={locale} pageType="notes-index" translations={translations}>
  <header class="page-header">
    <h1 class="page-title">{t.title}</h1>
    <p class="page-description">{t.description}</p>
  </header>

  <div class="notes-layout">
    <aside class="notes-sidebar">
      <NotesFilters categories={categories} categoryCounts={categoryCounts} tags={tags} noteTypes={noteTypes} noteTypeCounts={noteTypeCounts} locale={locale} />
    </aside>
    <div class="notes-content">
      <NotesGrid notes={notesToShow} locale={locale} />
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding-block-start: var(--space-8);
    margin-bottom: var(--space-12);
  }

  .page-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .page-description {
    font-size: var(--text-lg);
    color: var(--text-muted);
  }

  .notes-layout {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .notes-sidebar {
    position: sticky;
    top: var(--space-8);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  @media (max-width: 48rem) {
    .notes-layout {
      grid-template-columns: 1fr;
    }

    .notes-sidebar {
      position: static;
    }
  }
</style>
