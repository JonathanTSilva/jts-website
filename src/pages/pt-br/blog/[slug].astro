---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { contentLocalePath } from '../../../lib/content/locale';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const locale = 'pt-br';

  const uniqueTranslationKeys = Array.from(new Set(allPosts.map(p => p.data.translationKey)));
  
  return uniqueTranslationKeys.flatMap(key => {
    const translations = allPosts.filter(p => p.data.translationKey === key);
    
    // We generate a path for each translation's slug
    return translations.map(post => ({
      params: { slug: post.data.slug },
      props: { post, isTranslationFallback: post.data.language !== locale },
    }));
  });
}

const { post, isTranslationFallback } = Astro.props;
const { Content } = await render(post);

const locale = 'pt-br';

const t = {
  fallbackNotice: 'Este post não está disponível em Português. Mostrando a versão original.',
  viewOriginal: 'Ver versão original',
  publishedAt: 'Publicado em',
  backToBlog: '← Voltar para o blog',
};
---

<BaseLayout 
  locale={locale} 
  title={post.data.title} 
  description={post.data.summary}
>
  <article class="container">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.publishedAt.toISOString()}>
          {t.publishedAt} {post.data.publishedAt.toLocaleDateString(locale, { dateStyle: 'long' })}
        </time>
        {post.data.tags && post.data.tags.length > 0 && (
          <span class="post-tags">
            • {post.data.tags.join(', ')}
          </span>
        )}
      </div>
    </header>

    {isTranslationFallback && (
      <div class="fallback-notice">
        <p>{t.fallbackNotice}</p>
      </div>
    )}

    <div class="prose">
      <Content />
    </div>

    <footer class="post-footer">
      <a href={contentLocalePath(locale, '/blog')} class="back-link">
        {t.backToBlog}
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-8) 0;
  }
  .post-header {
    margin-bottom: var(--space-8);
  }
  .post-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-2);
  }
  .post-meta {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
  .fallback-notice {
    background-color: #fef3c7;
    border-left: 4px solid #f59e0b;
    padding: var(--space-4);
    margin-bottom: var(--space-8);
    color: #92400e;
  }
  .prose {
    line-height: 1.6;
  }
  .prose :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }
  .prose :global(p) {
    margin-bottom: var(--space-4);
  }
  .post-footer {
    margin-top: var(--space-12);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
  }
  .back-link {
    color: var(--accent);
    text-decoration: none;
  }
  .back-link:hover {
    text-decoration: underline;
  }
</style>
