---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { experience } from '../../content/portfolio/experience';
import { projects } from '../../content/portfolio/projects';
import { publications } from '../../content/portfolio/publications';
import ProjectCard from '../../components/portfolio/ProjectCard.astro';
import PublicationItem from '../../components/portfolio/PublicationItem.astro';
import TimelineItem from '../../components/portfolio/TimelineItem.astro';
import AboutSection from '../../components/portfolio/AboutSection.astro';

const locale = 'en';

const sortedExperience = [...experience].sort((a, b) =>
  b.startDate.localeCompare(a.startDate)
);

const t = {
  title: 'Portfolio',
  about: 'Biography',
  experience: 'Experience',
  projects: 'Projects',
  publications: 'Publications',
  downloadCv: 'Download CV (PDF)',
};
---

<BaseLayout locale={locale} title={t.title}>
  <div class="portfolio-wrapper">
    <div class="portfolio-header">
      <h1>{t.title}</h1>
      <a href="/assets/cv/jonathan-cv.pdf" download class="cv-button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {t.downloadCv}
      </a>
    </div>

    <AboutSection locale={locale} aboutLabel={t.about} />

    <section class="portfolio-section">
      <h2>{t.projects}</h2>
      <div class="bento-grid">
        {projects.map((project) => (
          <ProjectCard project={project} locale={locale} />
        ))}
      </div>
    </section>

    <section class="portfolio-section">
      <h2>{t.experience}</h2>
      <div class="timeline">
        {sortedExperience.map((entry) => (
          <TimelineItem entry={entry} locale={locale} />
        ))}
      </div>
    </section>

    <section class="portfolio-section">
      <h2>{t.publications}</h2>
      <div class="prose-constrained">
        <div class="pub-list">
          {publications.map((pub) => (
            <PublicationItem publication={pub} locale={locale} />
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .portfolio-wrapper {
    max-width: var(--wide-max);
    margin: 0 auto;
    width: 100%;
  }

  .portfolio-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-12);
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  h1 {
    font-size: var(--text-4xl);
    margin: 0;
  }

  .cv-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--accent);
    color: var(--bg);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-out);
  }
  .cv-button:hover { background: var(--accent-hover); }

  .portfolio-section {
    margin-bottom: var(--space-16);
  }

  h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-2);
    color: var(--text);
  }

  .prose-constrained {
    max-width: var(--container-max);
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .timeline {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* Vertical line connecting timeline dots */
  .timeline::before {
    content: '';
    position: absolute;
    left: calc(0.75rem - 1px);
    top: 4px;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (max-width: 640px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    /* On mobile, featured cards don't span 3 columns */
    .bento-grid :global(.project-card[style*="span"]) {
      grid-column: span 1 !important;
    }
  }
</style>
