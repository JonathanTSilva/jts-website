---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import HomeSections from '../components/home/HomeSections.astro';

const locale = 'en';

const translations = {
  en: '/',
  'pt-br': '/pt-br',
};

const t = {
  projects: 'Projects',
  publications: 'Publications',
  blog: 'Latest Blog Posts',
  notes: 'Latest Notes',
  seeAllPortfolio: 'See full portfolio',
  downloadCv: 'Download CV (PDF)',
  viewAllBlog: 'View all blog posts',
  viewAllNotes: 'View all notes',
  at: 'at',
  viewAllPublications: 'See all publications',
};
---

<BaseLayout locale={locale} title="Home" translations={translations}>
  <Hero locale="en" />
  <HomeSections locale={locale} t={t} />
</BaseLayout>
