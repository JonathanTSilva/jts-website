---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogList from '../../components/blog/BlogList.astro';

const locale = 'en';

const translations = {
  en: '/blog',
  'pt-br': '/pt-br/blog',
};

const t = {
  title: 'Blog',
  description: 'Writings on firmware, embedded systems, and automation.',
};
---

<BaseLayout locale={locale} title={t.title} description={t.description} translations={translations}>
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">{t.title}</h1>
      <p class="page-description">{t.description}</p>
    </header>

    <BlogList locale={locale} />
  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-8) 0;
  }
  .page-header {
    margin-bottom: var(--space-12);
  }
  .page-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }
  .page-description {
    font-size: var(--text-lg);
    color: var(--text-muted);
  }
</style>
