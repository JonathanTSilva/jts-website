{
  "name": "jts-website",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build:search": "tsx scripts/build-search-index.ts",
    "build": "pnpm build:search && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:update-missing": "playwright test --update-snapshots=missing",
    "test:e2e:install": "playwright install --with-deps",
    "test": "pnpm test:unit && pnpm test:e2e",
    "lint:content": "tsx scripts/validate-content.ts",
    "sync:content": "tsx scripts/sync-content.ts",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/patrick-hand": "^5.2.8",
    "astro": "^6.1.1",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.44",
    "marked": "^17.0.5",
    "mermaid": "^11.13.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "typescript": "^5.7.3",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.50.1",
    "@types/fs-extra": "^11.0.4",
    "@types/mdast": "^4.0.4",
    "fs-extra": "^11.3.4",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "unified": "^11.0.5",
    "vfile": "^6.0.3",
    "vitest": "^3.0.7"
  }
}
